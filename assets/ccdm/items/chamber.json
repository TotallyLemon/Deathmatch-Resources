{
  "model": {
    "type": "select",
    "cases": [
      {
        "model": {
          "type": "composite",
          "models": [
            {
              "type": "model",
              "model": "item/crossbow_arrow"
            },
            {
              "type": "model",
              "model": "ccdm:item/crossbow_tip",
              "tints": [
                {
                  "type": "custom_model_data",
                  "default": -1
                }
              ]
            },
            {
              "type": "select",
              "property": "display_context",
              "fallback": {
                "type": "empty"
              },
              "cases": [
                {
                  "model": {
                    "type": "composite",
                    "models": [
                      {
                        "type": "condition",
                        "property": "custom_model_data",
                        "on_false": {
                          "type": "empty"
                        },
                        "on_true": {
                          "type": "model",
                          "model": "ccdm:item/chamber/5",
                          "tints": [
                            {
                              "type": "custom_model_data",
                              "default": -1,
                              "index": 5
                            }
                          ]
                        },
                        "index": 5
                      },
                      {
                        "type": "condition",
                        "property": "custom_model_data",
                        "on_false": {
                          "type": "empty"
                        },
                        "on_true": {
                          "type": "model",
                          "model": "ccdm:item/chamber/4",
                          "tints": [
                            {
                              "type": "custom_model_data",
                              "default": -1,
                              "index": 4
                            }
                          ]
                        },
                        "index": 4
                      },
                      {
                        "type": "condition",
                        "property": "custom_model_data",
                        "on_false": {
                          "type": "empty"
                        },
                        "on_true": {
                          "type": "model",
                          "model": "ccdm:item/chamber/3",
                          "tints": [
                            {
                              "type": "custom_model_data",
                              "default": -1,
                              "index": 3
                            }
                          ]
                        },
                        "index": 3
                      },
                      {
                        "type": "condition",
                        "property": "custom_model_data",
                        "on_false": {
                          "type": "empty"
                        },
                        "on_true": {
                          "type": "model",
                          "model": "ccdm:item/chamber/2",
                          "tints": [
                            {
                              "type": "custom_model_data",
                              "default": -1,
                              "index": 2
                            }
                          ]
                        },
                        "index": 2
                      },
                      {
                        "type": "condition",
                        "property": "custom_model_data",
                        "on_false": {
                          "type": "empty"
                        },
                        "on_true": {
                          "type": "model",
                          "model": "ccdm:item/chamber/1",
                          "tints": [
                            {
                              "type": "custom_model_data",
                              "default": -1,
                              "index": 1
                            }
                          ]
                        },
                        "index": 1
                      },
                      {
                        "type": "condition",
                        "property": "custom_model_data",
                        "on_false": {
                          "type": "empty"
                        },
                        "on_true": {
                          "type": "model",
                          "model": "ccdm:item/chamber/0",
                          "tints": [
                            {
                              "type": "custom_model_data",
                              "default": -1,
                              "index": 0
                            }
                          ]
                        },
                        "index": 0
                      }
                    ]
                  },
                  "when": [
                    "gui"
                  ]
                }
              ]
            }
          ]
        },
        "when": "arrow"
      },
      {
        "model": {
          "type": "model",
          "model": "item/crossbow_firework"
        },
        "when": "rocket"
      }
    ],
    "fallback": {
      "type": "condition",
      "on_false": {
        "type": "model",
        "model": "item/crossbow"
      },
      "on_true": {
        "type": "range_dispatch",
        "entries": [
          {
            "model": {
              "type": "model",
              "model": "item/crossbow_pulling_1"
            },
            "threshold": 0.58
          },
          {
            "model": {
              "type": "model",
              "model": "item/crossbow_pulling_2"
            },
            "threshold": 1.0
          }
        ],
        "fallback": {
          "type": "model",
          "model": "item/crossbow_pulling_0"
        },
        "property": "crossbow/pull"
      },
      "property": "using_item"
    },
    "property": "charge_type"
  }
}